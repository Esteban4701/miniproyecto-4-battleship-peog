<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Single-screen layout for the whole game (see GameScreenController).
  The 3D BattlefieldView3D is inserted at runtime as the background
  layer of rootStack (see GameScreenController#initialize); everything
  declared here is a 2D overlay drawn on top of it.

  Usability heuristics applied:
   - Visibility of system status: the placement HUD always shows which
     ship is next and its orientation; the game-over overlay makes the
     outcome unmissable.
   - User control and freedom: "Volver al inicio" always offers a clear
     way back out of a finished game.
   - Error prevention: the nickname field is validated before "Nuevo
     Juego" is allowed to proceed (see onNewGameClicked), with an
     inline hint instead of a silent failure or a popup dialog.
-->
<StackPane fx:id="rootStack" xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.battleship.controller.GameScreenController"
           prefWidth="1100" prefHeight="800"
           styleClass="root-stack">

    <VBox fx:id="startMenuPane" alignment="CENTER" spacing="18" styleClass="start-menu-pane">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        <Label text="Batalla Naval" styleClass="title-label"/>
        <TextField fx:id="nicknameField" promptText="Tu nombre" maxWidth="260"/>
        <HBox alignment="CENTER" spacing="14">
            <Button fx:id="newGameButton" text="Nuevo Juego" onAction="#onNewGameClicked" defaultButton="true"/>
            <Button fx:id="continueButton" text="Continuar" onAction="#onContinueClicked"/>
        </HBox>
        <Label fx:id="startMenuHintLabel" text="Escribe tu nombre para comenzar" styleClass="hint-label"/>
    </VBox>

    <VBox fx:id="placementHudPane" alignment="TOP_CENTER" visible="false" managed="false" styleClass="placement-hud-pane">
        <padding>
            <Insets top="24"/>
        </padding>
        <Label fx:id="placementInstructionLabel" text="" styleClass="hud-label"/>
        <Label text="Presiona R para rotar el barco" styleClass="hud-sublabel"/>
    </VBox>

    <StackPane fx:id="gameOverPane" alignment="CENTER" visible="false" managed="false" styleClass="game-over-pane">
        <VBox alignment="CENTER" spacing="16">
            <Label fx:id="gameOverLabel" text="" styleClass="game-over-label"/>
            <Button text="Volver al inicio" onAction="#onBackToMenuClicked"/>
        </VBox>
    </StackPane>

</StackPane>
